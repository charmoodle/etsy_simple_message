{
  "manifest_version": 3,
  "name": "Etsy Message Assistant",
  "version": "1.0.0",
  "description": "AI-powered message assistant for Etsy shops",
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["https://www.etsy.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.etsy.com/messages/*", "https://www.etsy.com/your/shops/*/tools/messages*"],
      "js": ["responses.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
